    {
      "name": "ec_alias_reg",
      "description": "event_class == 'reg' — alias for Registry (idx 147-149)",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "==", "reg", "include"], ["event_index", ">=", "147", "include"], ["event_index", "<=", "149", "include"]],
      "select_fields": ["event_class", "operation"],
      "expected": {
        "total_count": 3,
        "all_events": {"event_class": "Registry"}
