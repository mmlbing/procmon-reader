{
  "_comment": "Alias & normalisation tests for build_filter_tree, run via test_event.py. Source: Logfile.zip",
  "test_cases": [

    {
      "name": "alias_num_is",
      "description": "pid 'is' 744 — alias for ==",
      "pml_file": "res/Logfile.zip",
      "filters": [["pid", "is", "744", "include"], ["event_index", "<=", "1", "include"]],
      "select_fields": ["event_class", "process_name", "pid"],
      "expected": {
        "total_count": 2,
        "all_events": {"process_name": "lsass.exe", "pid": 744}
      }
    },
    {
      "name": "alias_num_equals",
      "description": "pid 'equals' 744 — alias for ==",
      "pml_file": "res/Logfile.zip",
      "filters": [["pid", "equals", "744", "include"], ["event_index", "<=", "1", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 2,
        "all_events": {"process_name": "lsass.exe", "pid": 744}
      }
    },
    {
      "name": "alias_num_is_not",
      "description": "pid 'is_not' 744 within idx 0-2 — should get only idx 2 (pid 0)",
      "pml_file": "res/Logfile.zip",
      "filters": [["pid", "is_not", "744", "include"], ["event_index", "<=", "2", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
        "first_event": {"process_name": "Idle", "pid": 0}
      }
    },
    {
      "name": "alias_num_not_equals",
      "description": "pid 'not_equals' 744 within idx 0-2",
      "pml_file": "res/Logfile.zip",
      "filters": [["pid", "not_equals", "744", "include"], ["event_index", "<=", "2", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
        "first_event": {"process_name": "Idle", "pid": 0}
      }
    },
    {
      "name": "alias_num_le",
      "description": "event_index 'le' 2 — alias for <=",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_index", "le", "2", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 3
      }
    },
    {
      "name": "alias_num_less_equal",
      "description": "event_index 'less_equal' 2",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_index", "less_equal", "2", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 3
      }
    },
    {
      "name": "alias_num_ge",
      "description": "event_index 'ge' 108238 — alias for >=, last event",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_index", "ge", "108238", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
        "first_event": {"process_name": "svchost.exe", "pid": 6328}
      }
    },
    {
      "name": "alias_num_more_equal",
      "description": "event_index 'more_equal' 108238",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_index", "more_equal", "108238", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
        "first_event": {"process_name": "svchost.exe", "pid": 6328}
      }
    },


    {
      "name": "alias_str_is",
      "description": "process_name 'is' lsass.exe — alias for ==",
      "pml_file": "res/Logfile.zip",
      "filters": [["process_name", "is", "lsass.exe", "include"], ["event_index", "<=", "1", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 2,
        "all_events": {"process_name": "lsass.exe", "pid": 744}
      }
    },
    {
      "name": "alias_str_equals",
      "description": "process_name 'equals' lsass.exe",
      "pml_file": "res/Logfile.zip",
      "filters": [["process_name", "equals", "lsass.exe", "include"], ["event_index", "<=", "1", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 2,
        "all_events": {"process_name": "lsass.exe", "pid": 744}
      }
    },
    {
      "name": "alias_str_is_not",
      "description": "process_name 'is_not' lsass.exe within idx 0-2",
      "pml_file": "res/Logfile.zip",
      "filters": [["process_name", "is_not", "lsass.exe", "include"], ["event_index", "<=", "2", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
