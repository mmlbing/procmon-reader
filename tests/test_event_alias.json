      "pml_file": "res/Logfile.zip",
      "filters": [["process_name", "not_equals", "lsass.exe", "include"], ["event_index", "<=", "2", "include"]],
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
        "first_event": {"process_name": "Idle", "pid": 0}
      }
    },


    {
