    {
      "name": "ec_alias_proc",
      "description": "event_class == 'proc' — alias for Process (idx 225)",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "==", "proc", "include"], ["event_index", "==", "225", "include"]],
      "select_fields": ["event_class", "operation"],
      "expected": {
        "total_count": 1,
        "first_event": {"event_class": "Process", "operation": "Load Image"}
      }
    },
    {
      "name": "ec_alias_net",
      "description": "event_class == 'net' — alias for Network (idx 215-216)",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "==", "net", "include"], ["event_index", ">=", "215", "include"], ["event_index", "<=", "216", "include"]],
      "select_fields": ["event_class", "operation"],
      "expected": {
        "total_count": 2,
        "all_events": {"event_class": "Network"}
