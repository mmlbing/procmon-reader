    {
      "name": "ec_alias_filesystem_nospace",
      "description": "event_class == 'FileSystem'",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "==", "FileSystem", "include"], ["event_index", "<=", "1", "include"]],
      "select_fields": ["event_class"],
