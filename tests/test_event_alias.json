    },
    {
      "name": "ec_alias_prof",
      "description": "event_class == 'prof' — alias for Profiling (idx 2)",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "==", "prof", "include"], ["event_index", "==", "2", "include"]],
      "select_fields": ["event_class", "operation", "process_name"],
      "expected": {
        "total_count": 1,
        "first_event": {"event_class": "Profiling", "operation": "Process Profiling", "process_name": "Idle"}
      }
    },
    {
      "name": "ec_case_insensitive",
      "description": "event_class == 'FILE SYSTEM' — case insensitive",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "==", "FILE SYSTEM", "include"], ["event_index", "<=", "1", "include"]],
      "select_fields": ["event_class"],
      "expected": {
        "total_count": 2,
        "all_events": {"event_class": "File System"}
      }
    },
    {
      "name": "ec_neq_alias_exclude_profiling",
      "description": "event_class != 'prof' within idx 0-2 — excludes idx 2 (Profiling)",
      "pml_file": "res/Logfile.zip",
      "filters": [["event_class", "!=", "prof", "include"], ["event_index", "<=", "2", "include"]],
      "select_fields": ["event_class", "process_name"],
      "expected": {
        "total_count": 2,
        "all_events": {"event_class": "File System", "process_name": "lsass.exe"}
      }
    },


    {
      "name": "dsl_alias_is",
      "description": "DSL: pid 'is' 744 (idx 0-1)",
      "pml_file": "res/Logfile.zip",
      "filters": {"AND": [["pid", "is", "744"], ["event_index", "<=", "1"]]},
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 2,
        "all_events": {"process_name": "lsass.exe", "pid": 744}
      }
    },
    {
