      }
    },
    {
      "name": "dsl_alias_gt_ge",
      "description": "DSL: event_index 'ge' 108238 AND 'more_equal' 108238 — last event",
      "pml_file": "res/Logfile.zip",
      "filters": {"AND": [["event_index", "ge", "108238"], ["event_index", "more_equal", "108238"]]},
      "select_fields": ["process_name", "pid"],
      "expected": {
        "total_count": 1,
        "first_event": {"process_name": "svchost.exe", "pid": 6328}
      }
    },
    {
      "name": "dsl_ec_alias_fs",
      "description": "DSL: event_class == 'fs' (idx 0-1)",
