      }
    },
    {
      "name": "dsl_alias_lt_le",
      "description": "DSL: event_index 'le' 1 — gets first 2 events",
      "pml_file": "res/Logfile.zip",
      "filters": {"AND": [["event_index", "le", "1"], ["pid", "==", "744"]]},
      "select_fields": ["process_name"],
